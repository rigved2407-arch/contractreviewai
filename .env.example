# ═══════════════════════════════════════════════════════
# SECURITY WARNING: This file is for DEVELOPMENT ONLY.
# In production, NEVER store secrets in a .env file.
#   Use Docker secrets (recommended): deploy/README.md
#   Or cloud vaults: deploy/scripts/aws-secrets.py
#                   deploy/scripts/azure-secrets.py
# ═══════════════════════════════════════════════════════

# === LLM Provider ===
# Supports OpenAI, Groq, Azure OpenAI, or any OpenAI-compatible API
# For Groq: https://api.groq.com/openai/v1
# For OpenAI: https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# === Database ===
# Production: PostgreSQL (recommended — handles concurrent users)
#   docker-compose users: postgresql://cra:cra_secret_2024@db:5432/contract_review
# Local dev (sqlite): sqlite:///./data/contract_review.db
DATABASE_URL=postgresql://cra:cra_secret_2024@db:5432/contract_review

# === Storage ===
STORAGE_DIR=./data/storage
MAX_UPLOAD_SIZE_MB=50

# === Security: Encryption ===
ENCRYPT_DOCUMENTS=true
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# === Security: Authentication ===
AUTH_ENABLED=true
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
API_KEY=

# === Audit & Data Retention ===
AUDIT_ENABLED=true
DATA_RETENTION_DAYS=365
AUTO_DELETE_EXPIRED=false

# === LLM Privacy ===
LLM_DATA_LOGGING=false
LLM_REDACT_PII=false

# === Azure OpenAI (optional) ===
LLM_USE_AZURE=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=

# === India Compliance (DPDP Act) ===
DPDP_COMPLIANCE=true
DATA_RESIDENCY=india

# === CORS ===
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# === JWT Auth (for user registration / login) ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
APP_URL=http://localhost:3000

# === SMTP / Email (for welcome, invoice, and analysis-done emails) ===
# Leave blank to skip sending emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@contractreviewai.com
SMTP_FROM_NAME=Contract Review AI
